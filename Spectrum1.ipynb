{
 "cells": [
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import scipy",
    "import numpy as np",
    "import matplotlib.pyplot as plt",
    "from scipy.special import roots_legendre"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Stage 1: Construct an initial quadrature on X"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "## X is a Rectangle [0,2] x [-1,1]",
    "a, b = 0, 2",
    "c, d = -1, 1",
    "n = 5",
    "",
    "roots, weights = roots_legendre(n)",
    "mapped_roots1 = a + (b - a) * (roots + 1) / 2",
    "mapped_roots2 = c + (d - c) * (roots + 1) / 2",
    "mapped_weights1 = (b - a) * weights / 2",
    "mapped_weights2 = (d - c) * weights / 2",
    "",
    "tensor_w = mapped_weights1.reshape(n, 1) @ mapped_weights2.reshape(1, n)",
    "quad_x, quad_y = np.meshgrid(mapped_roots1, mapped_roots2, indexing=\"ij\")",
    "quad_points = np.column_stack([quad_x.ravel(), quad_y.ravel()])",
    "quad_weights = tensor_w.ravel()",
    "",
    "NN = (n + 1) * (n + 2) // 2"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.title(\"Tensor-product quadrature on [0, 2] x [-1, 1]\")",
    "plt.scatter(quad_points[:, 0], quad_points[:, 1], s=8, c=\"black\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Stage 2: Construct an orthonormal basis of the space $P_n$"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def monomial_powers(d):",
    "    return [(i, j) for i in range(d + 1) for j in range(d + 1 - i)]",
    "",
    "def monomial_vandermonde(points, d):",
    "    powers = monomial_powers(d)",
    "    V = np.empty((len(points), len(powers)), dtype=float)",
    "    for col, (i, j) in enumerate(powers):",
    "        V[:, col] = (points[:, 0] ** i) * (points[:, 1] ** j)",
    "    return V, powers",
    "",
    "def int_f(f, _n=None):",
    "    values = np.array([f(x, y) for x, y in quad_points], dtype=complex)",
    "    return np.dot(quad_weights, values)",
    "",
    "def eval_vec(vec, x, y, n):",
    "    value = 0.0",
    "    for coeff, (i, j) in zip(vec, monomial_powers(n)):",
    "        value += coeff * (x ** i) * (y ** j)",
    "    return value",
    "",
    "def eval_xderivative(vec, x, y, n):",
    "    value = 0.0",
    "    for coeff, (i, j) in zip(vec, monomial_powers(n)):",
    "        if i:",
    "            value += coeff * i * (x ** (i - 1)) * (y **    return value",
 j)",
    "    "",
    "def eval_yderivative(vec, x, y, n):",
    "    value = 0.0",
    "    for coeff, (i, j) in zip(vec, monomial_powers(n)):",
    "        if j:",
    "            value += coeff * j * (x ** i) * (y ** (j - 1))",
    "    return value",
    "",
    "def find_basis(d):",
    "    V, _ = monomial_vandermonde(quad_points, d)",
    "    weighted_V = np.sqrt(quad_weights)[:, None] * V",
    "    _, R = np.linalg.qr(weighted_V, mode=\"reduced\")",
    "    coeffs = scipy.linalg.solve_triangular(R, np.eye(R.shape[0]))",
    "    return [coeffs[:, i].reshape(-1, 1) for i in range(coeffs.shape[1])]",
    "",
    "basis = find_basis(n)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "i,j = 2,5",
    "f = lambda m,n: m**i * n**j",
    "int_f(f, n)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Stage 3: Find the eigenvalues of $P_U \\circ M_{x+iy}$"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "N = len(basis)",
    "",
    "A = np.zeros((N, N), dtype=complex)",
    "",
    "for i in range(N):",
    "    for j in range(N):",
    "        f = lambda x, y: complex(x, y) * eval_vec(basis[i].flatten(), x, y, n) * np.conj(eval_vec(basis[j].flatten(), x, y, n))",
    "        A[i][j] = int_f(f, n)",
    "eigens = scipy.linalg.eigvals(A)",
    "X, Y = eigens.real, eigens.imag"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.scatter(X, Y, s=1, c='black')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Stage 4: Construct the quadrature"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "m = n",
    "M = (m + 1) * (m + 2) // 2",
    "basis_m = find_basis(m)",
    "",
    "I = np.array([",
    "    int_f(lambda x, y, j=j: eval_vec(basis_m[j].flatten(), x, y, m))",
    "    for j in range(M)",
    "])",
    "",
    "phi = np.zeros((M, eigens.shape[0]))",
    "for i in range(M):",
    "    p = basis_m[i].flatten()",
    "    for j in range(eigens.shape[0]):",
    "        phi[i, j] = np.real_if_close(eval_vec(p, X[j], Y[j], m))",
    "",
    "omega = np.real_if_close(scipy.linalg.lstsq(phi, I)[0])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "x0 = np.concatenate([X, Y, omega])",
    "",
    "def F(point):",
    "    x = point[:NN]",
    "    y = point[NN:2 * NN]",
    "    w = point[2 * NN:]",
    "    res = np.zeros(M)",
    "    for i in range(M):",
    "        vals = np.array([eval_vec(basis_m[i].flatten(), x[j], y[j], m) for j in range(NN)])",
    "        res[i] = vals @ w",
    "    return res - I",
    "",
    "def residual(point):",
    "    return (F(point) ** 2).sum()",
    "",
    "def J(point):",
    "    x = point[:NN]",
    "    y = point[NN:2 * NN]",
    "    w = point[2 * NN:]",
    "",
    "    res = np.zeros((M, 3 * NN))",
    "    for i in range(M):",
    "        dx = np.array([eval_xderivative(basis_m[i].flatten(), x[j], y[j], m) for j in range(NN)]) * w",
    "        dy = np.array([eval_yderivative(basis_m[i].flatten(), x[j], y[j], m) for j in range(NN)]) * w",
    "        dw = np.array([eval_vec(basis_m[i].flatten(), x[j], y[j], m) for j in range(NN)])",
    "        res[i] = np.concatenate([dx, dy, dw], axis=0)",
    "    return res",
    "",
    "def line_search(p, point):",
    "    alpha = 0.1",
    "    while (F(point + alpha * p) > F(point) + 0.3 * alpha * J(point) @ p).any():",
    "        alpha *= 0.8",
    "        if alpha <= 1e-100:",
    "            break",
    "    return alpha",
    "",
    "tol = 1e-8",
    "point = x0",
    "A = np.eye(3 * NN)",
    "mu = 1e-9",
    "",
    "for i in range(100):",
    "    print(i)",
    "    p = scipy.linalg.inv(J(point).T @ J(point) + mu * A) @ (J(point).T) @ F(point)",
    "    alpha = line_search(p, point)",
    "    point_proposal = point - p * alpha",
    "",
    "    if residual(point_proposal) <= tol:",
    "        point = point_proposal",
    "        break",
    "",
    "    point = point_proposal"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Results"
   ]
  },
  {
   "cell_type": "code",
